# ──────────────────────────────────────────────────────────
# go-rag-starter configuration
#
# docker-compose.yml wires these up automatically — you only need this
# file if you run the binary outside compose (e.g. bare metal, k8s).
# ──────────────────────────────────────────────────────────

# LLM backend — Ollama by default. To swap for OpenAI / Anthropic / Bedrock,
# see docs/03-swap-the-llm.md.
OLLAMA_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=gemma3:4b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Database. Must be Postgres with the pgvector extension available
# (pgvector/pgvector:pg16 is the standard community image).
DB_DSN=postgres://ragbot:ragbot@localhost:5432/ragbot?sslmode=disable

# Service
SERVICE_PORT=8080

# System-prompt tuning. These strings are interpolated into the prompt
# the model sees on every query. Keep them short and factual.
PRODUCT_NAME=MyApp
PRODUCT_BLURB=a short description of what MyApp is.
REFUSE_PHRASE=I don't have that in the docs yet — try asking something else, or check the project README.
