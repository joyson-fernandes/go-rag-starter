# docker-compose.override.yml.example
#
# Rename to `docker-compose.override.yml` (no `.example`) to activate.
# Docker Compose automatically layers `docker-compose.override.yml` on top of
# `docker-compose.yml` — so anything in here overrides the defaults.
#
# ──────────────────────────────────────────────────────────────────────────
# Use case: skip the bundled Ollama container and point at an Ollama you
# installed on the host machine. Typical reasons:
#
#   - macOS: Docker containers can't access Metal (Apple's GPU), so the
#     bundled Ollama is CPU-only and painfully slow.
#   - Windows without an NVIDIA GPU: same pain as macOS.
#   - Linux without an NVIDIA GPU: optional — bundled Ollama works, but
#     a host Ollama saves you the 3.3 GB container + avoids a double copy.
#
# If you HAVE an NVIDIA GPU (Linux or Windows/WSL2), use
# docker-compose.gpu.yml.example instead — it enables GPU passthrough on
# the bundled container and is simpler.
#
# Prereqs on the host:
#   macOS:   brew install ollama && brew services start ollama
#   Windows: install Ollama from https://ollama.com/download
#   Linux:   curl -fsSL https://ollama.com/install.sh | sh
#   ollama pull gemma4:26b          # or any chat model from docs/03-swap-the-llm.md
#   ollama pull nomic-embed-text
#
# Then:
#   cp docker-compose.override.yml.example docker-compose.override.yml
#   docker-compose up
# ──────────────────────────────────────────────────────────────────────────

services:
  ragbot:
    # Drop the dependency on the (slow, CPU-only) container Ollama.
    depends_on:
      postgres:
        condition: service_healthy
    environment:
      OLLAMA_URL: http://host.docker.internal:11434
      OLLAMA_CHAT_MODEL: gemma4:26b
      OLLAMA_EMBED_MODEL: nomic-embed-text
    # Linux note: host.docker.internal does NOT resolve by default. The
    # extra_hosts line below makes it resolve to the host gateway. macOS
    # and Windows Docker Desktop add this mapping automatically — but it's
    # harmless to set it everywhere.
    extra_hosts:
      - "host.docker.internal:host-gateway"
